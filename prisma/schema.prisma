generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  password   String
  businesses Business[]
  uploads    Upload[]
  role       UserRole   @default(GYM_OWNER)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Upload {
  id           String   @id @default(cuid())
  user         User     @relation(fields: [userId], references: [id])
  userId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  path         String
  createdAt    DateTime @default(now())
  @@index([userId])
}

model Business {
  id             String   @id @default(cuid())

  user           User     @relation(fields: [userId], references: [id])
  userId         String

  businessName   String
  category       String?
  city           String?
  phone          String?
  logoUrl        String?

  heroTitle      String?
  heroSubtitle   String?
  aboutText      String?

  services       Json?
  features       Json?
  testimonials   Json?
  websiteContent Json?

  seoTitle       String?
  seoDescription String?

  templateId     String?
  themeColor     String?
  fontStyle      String?

  subdomain      String?  @unique
  isActive       Boolean  @default(true)
  isPublished    Boolean  @default(false)
  publishedAt    DateTime?
  subscriptionStatus SubscriptionStatus @default(FREE)
  customDomain   String?
  planType       String?
  whatsappNumber String?
  whatsappEnabled Boolean @default(false)
  ctaLabels      Json?
  websiteViews   Int      @default(0)
  leadCount      Int      @default(0)
  ctaClicks      Int      @default(0)
  membershipPlans MembershipPlan[]
  leads          Lead[]
  activities     BusinessActivity[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@index([userId])
}

model BusinessActivity {
  id         String                 @id @default(cuid())
  business   Business               @relation(fields: [businessId], references: [id])
  businessId String
  type       BusinessActivityType
  message    String?
  metadata   Json?
  createdAt  DateTime               @default(now())

  @@index([businessId])
  @@index([createdAt])
  @@index([businessId, type])
}

model MembershipPlan {
  id          String   @id @default(cuid())
  business    Business @relation(fields: [businessId], references: [id])
  businessId  String
  name        String
  price       Float
  duration    Int
  description String?
  features    Json?
  isPopular   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
}

model Lead {
  id             String   @id @default(cuid())
  business       Business @relation(fields: [businessId], references: [id])
  businessId     String
  name           String
  email          String
  phone          String?
  message        String?
  interestedPlan String?
  createdAt      DateTime @default(now())

  @@index([businessId])
}

enum UserRole {
  SUPER_ADMIN
  GYM_OWNER
}

enum BusinessActivityType {
  WEBSITE_PUBLISHED
  WEBSITE_UNPUBLISHED
  LEAD_SUBMITTED
  MEMBERSHIP_CREATED
  CTA_CLICKED
  WEBSITE_VIEWED
}

enum SubscriptionStatus {
  FREE
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}
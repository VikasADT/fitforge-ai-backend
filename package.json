{
  "name": "fitforge-ai-backend",
  "version": "1.0.0",
  "description": "AI-powered gym website generator backend",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
